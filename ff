{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "display": {
    "key": {
      "width": 10
    },
    "size": {
      "binaryPrefix": "jedec"
    },
    "separator": ""
  },
  "logo": {
    "type": "kitty-direct",
    "source": "~/.config/fastfetch/logo/logo3.png",
    "width": 28,
    "height": 14,
    "padding": {
      "top": 0,
      "left": 1
    }
  },
  "modules": [
    "break",
    {
      "type": "title",
      "key": "usr",
      "format": "{user-name}"
    },
    {
      "type": "os",
      "key": "os",
      "format": "{name}"
    },
    {
      "type": "kernel",
      "key": "ker"
    },
    {
      "type": "shell",
      "key": "sh",
      "format": "{pretty-name}"
    },
    {
      "type": "terminal",
      "key": "ter",
      "format": "{pretty-name}"
    },
    {
      "type": "packages",
      "key": "pkgs"
    },
    {
      "type": "wm",
      "key": "wm"
    },
    {
      "type": "terminalfont",
      "key": "fn"
    },
    {
      "type": "cpu",
      "key": "cpu",
      "format": "{name}"
    },
    {
      "type": "gpu",
      "key": "gpu",
      "format": "{name}"
    },
    {
      "type": "memory",
      "key": "ram",
      "format": "{used} / {total}"
    },
    "break",
    {
      "type": "custom",
      "format": "\"Immortal Venerables regret but I do not\""
    },
    "break",
    {
      "type": "colors",
      "symbol": "circle"
    },
    "break"
  ]
}
